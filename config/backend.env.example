# Referencia FIAP para conexao Oracle via terminal ou API
ORACLE_HOST=seu_host_oracle
ORACLE_PORT=1521
ORACLE_SERVICE=seu_service_name
# Usuario normalmente corresponde ao acesso Oracle fornecido para a disciplina
ORACLE_USER=seu_rm
# Informe a senha valida do seu ambiente Oracle
ORACLE_PASSWORD=sua_senha
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://seu-front.vercel.app
